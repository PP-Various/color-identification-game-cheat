{
    "manifest_version": 3,
    "name": "Color Identification Game Bot",
    "version": "1.2",
    "description": "私はただ、限界が知りたかっただけなんだ...\n色を見分けるゲームを自動で攻略する拡張機能\nスコア繁栄に時間がかかります...",
    "permissions": [
        "storage"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://shikisai101.com/app/color-identification-game/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_end"
        }
    ]
}